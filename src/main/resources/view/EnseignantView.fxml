<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.EnseignantController"
            styleClass="main-container">

    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="15">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Label text="&#128218; Gestion des Notes" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblNomEnseignant" text="Enseignant" styleClass="header-role"/>
            <Button text="&#128682; Deconnexion" onAction="#handleLogout" styleClass="btn-logout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="15">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

            <!-- Sous-Module Selection -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Sous-Module:" styleClass="field-label"/>
                <ComboBox fx:id="cbSousModules" promptText="Selectionner un sous-module" prefWidth="300" styleClass="combo-modern"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblMoyenneClasse" text="Moyenne classe: -" styleClass="info-label"/>
            </HBox>

            <!-- Note Entry -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Note:" styleClass="field-label"/>
                <TextField fx:id="txtNote" promptText="0-20" prefWidth="80" styleClass="text-field-modern"/>
                <ComboBox fx:id="cbTypeNote" promptText="Type" prefWidth="150" styleClass="combo-modern"/>
                <Button text="&#128221; Saisir Note" onAction="#handleSaisirNote" styleClass="btn-primary"/>
                <Button text="&#128194; Importer Excel" onAction="#handleImporterNotes" styleClass="btn-secondary"/>
            </HBox>

            <!-- Students Table -->
            <Label text="Liste des Etudiants" styleClass="section-title"/>
            <TableView fx:id="tblEtudiants" VBox.vgrow="ALWAYS" styleClass="table-modern">
                <columns>
                    <TableColumn fx:id="colCne" text="CNE" prefWidth="100"/>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="150"/>
                    <TableColumn fx:id="colPrenom" text="Prenom" prefWidth="150"/>
                    <TableColumn fx:id="colNote" text="Note" prefWidth="80"/>
                </columns>
            </TableView>

            <!-- Notes History -->
            <Label text="Notes Saisies" styleClass="section-title"/>
            <TableView fx:id="tblNotes" prefHeight="200" styleClass="table-modern">
                <columns>
                    <TableColumn text="Etudiant" prefWidth="200"/>
                    <TableColumn text="Note" prefWidth="80"/>
                    <TableColumn text="Type" prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
