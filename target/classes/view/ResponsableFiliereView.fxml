<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ResponsableFiliereController"
            styleClass="main-container">

    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="15">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Label text="&#128218; Gestion des Notes" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblNomResponsable" text="Responsable Filiere" styleClass="header-role"/>
            <Button text="&#128682; Deconnexion" onAction="#handleLogout" styleClass="btn-logout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="15">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Promotion:" styleClass="field-label"/>
                <ComboBox fx:id="cbPromotions" promptText="Selectionner promotion" prefWidth="250" styleClass="combo-modern"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblTauxReussite" text="Taux reussite: -" styleClass="info-label"/>
                <Button text="&#128196; Exporter Rapport" onAction="#handleExporterRapport" styleClass="btn-primary"/>
            </HBox>

            <HBox spacing="15" VBox.vgrow="ALWAYS">
                <VBox spacing="10" HBox.hgrow="ALWAYS" prefWidth="50%">
                    <Label text="Etudiants" styleClass="section-title"/>
                    <TableView fx:id="tblEtudiants" VBox.vgrow="ALWAYS" styleClass="table-modern">
                        <columns>
                            <TableColumn fx:id="colCne" text="CNE" prefWidth="100"/>
                            <TableColumn fx:id="colNom" text="Nom" prefWidth="120"/>
                            <TableColumn fx:id="colPrenom" text="Prenom" prefWidth="120"/>
                            <TableColumn fx:id="colEmail" text="Email" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox spacing="10" HBox.hgrow="ALWAYS" prefWidth="50%">
                    <Label text="Notes" styleClass="section-title"/>
                    <TableView fx:id="tblNotes" VBox.vgrow="ALWAYS" styleClass="table-modern"/>
                </VBox>
            </HBox>

            <Label text="Classement" styleClass="section-title"/>
            <TableView fx:id="tblClassement" prefHeight="200" styleClass="table-modern"/>
        </VBox>
    </center>
</BorderPane>
