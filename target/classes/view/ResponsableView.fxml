<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ResponsableController"
            styleClass="main-container">

    <!-- Top Header -->
    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="15">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Label text="&#128218; Gestion des Notes" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Responsable Planning" styleClass="header-role"/>
            <Button text="&#128682; Deconnexion" onAction="#handleLogout" styleClass="btn-logout"/>
        </HBox>
    </top>

    <!-- Dashboard Stats -->
    <left>
        <VBox spacing="15" styleClass="sidebar" minWidth="200" maxWidth="200">
            <padding><Insets top="20" right="15" bottom="20" left="15"/></padding>

            <Label text="Tableau de Bord" styleClass="sidebar-title"/>

            <VBox styleClass="stat-card">
                <Label text="Etudiants" styleClass="stat-label"/>
                <Label fx:id="lblStatTotalEtudiants" text="0" styleClass="stat-value"/>
            </VBox>

            <VBox styleClass="stat-card">
                <Label text="Promotions" styleClass="stat-label"/>
                <Label fx:id="lblStatTotalPromos" text="0" styleClass="stat-value"/>
            </VBox>

            <VBox styleClass="stat-card">
                <Label text="Modules" styleClass="stat-label"/>
                <Label fx:id="lblStatTotalModules" text="0" styleClass="stat-value"/>
            </VBox>

            <VBox styleClass="stat-card">
                <Label text="Sous-Modules" styleClass="stat-label"/>
                <Label fx:id="lblStatTotalSousModules" text="0" styleClass="stat-value"/>
            </VBox>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <TabPane fx:id="tabPane" styleClass="main-tab-pane" tabClosingPolicy="UNAVAILABLE">

            <!-- Tab: Etudiants -->
            <Tab fx:id="tabEtudiants" text="&#128100; Etudiants">
                <VBox spacing="15">
                    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                    <!-- Toolbar -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="txtSearchEtudiant" promptText="&#128269; Rechercher..." prefWidth="250" styleClass="search-field"/>
                        <ComboBox fx:id="cbFilterPromotion" promptText="Filtrer par promotion" prefWidth="200" styleClass="combo-modern"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="&#128194; Importer Excel" onAction="#handleImporterEtudiants" styleClass="btn-secondary"/>
                        <Button text="&#128190; Exporter PDF" onAction="#handleExporterListeEtudiants" styleClass="btn-secondary"/>
                        <Button text="&#10133; Ajouter" onAction="#handleAjouterEtudiant" styleClass="btn-primary"/>
                        <Button text="&#9998; Modifier" onAction="#handleModifierEtudiant" styleClass="btn-secondary"/>
                        <Button text="&#128193; Archiver" onAction="#handleArchiverEtudiant" styleClass="btn-warning"/>
                    </HBox>

                    <!-- Stats -->
                    <HBox spacing="20">
                        <HBox styleClass="info-badge" spacing="5">
                            <Label text="Total:" styleClass="badge-label"/>
                            <Label fx:id="lblTotalEtudiants" text="0" styleClass="badge-value"/>
                        </HBox>
                        <HBox styleClass="info-badge-success" spacing="5">
                            <Label text="Actifs:" styleClass="badge-label"/>
                            <Label fx:id="lblActifs" text="0" styleClass="badge-value"/>
                        </HBox>
                        <HBox styleClass="info-badge-warning" spacing="5">
                            <Label text="Archives:" styleClass="badge-label"/>
                            <Label fx:id="lblArchives" text="0" styleClass="badge-value"/>
                        </HBox>
                    </HBox>

                    <!-- Table -->
                    <TableView fx:id="tblEtudiants" VBox.vgrow="ALWAYS" styleClass="table-modern">
                        <columns>
                            <TableColumn fx:id="colCne" text="CNE" prefWidth="100"/>
                            <TableColumn fx:id="colNom" text="Nom" prefWidth="120"/>
                            <TableColumn fx:id="colPrenom" text="Prenom" prefWidth="120"/>
                            <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                            <TableColumn fx:id="colStatut" text="Statut" prefWidth="80"/>
                            <TableColumn fx:id="colPromotion" text="Promotion" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Tab: Promotions -->
            <Tab fx:id="tabPromotions" text="&#127891; Promotions">
                <VBox spacing="15">
                    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="txtPromoIntitule" promptText="Intitule promotion" prefWidth="200" styleClass="text-field-modern"/>
                        <TextField fx:id="txtPromoAnnee" promptText="Annee (ex: 2024)" prefWidth="150" styleClass="text-field-modern"/>
                        <ComboBox fx:id="cbPromoFiliere" promptText="Filiere" prefWidth="200" styleClass="combo-modern"/>
                        <Button text="&#10133; Ajouter" onAction="#handleAjouterPromotion" styleClass="btn-primary"/>
                        <Button text="&#128465; Supprimer" onAction="#handleSupprimerPromotion" styleClass="btn-danger"/>
                    </HBox>

                    <TableView fx:id="tblPromotions" VBox.vgrow="ALWAYS" styleClass="table-modern">
                        <columns>
                            <TableColumn fx:id="colPromoIntitule" text="Intitule" prefWidth="200"/>
                            <TableColumn fx:id="colPromoAnnee" text="Annee" prefWidth="80"/>
                            <TableColumn fx:id="colPromoFiliere" text="Filiere" prefWidth="200"/>
                            <TableColumn fx:id="colPromoEtudiants" text="Etudiants" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Tab: Modules -->
            <Tab fx:id="tabModules" text="&#128218; Modules">
                <VBox spacing="15">
                    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <ComboBox fx:id="cbModulePromotion" promptText="Selectionner promotion" prefWidth="200" styleClass="combo-modern"/>
                        <Button text="&#128260; Charger" onAction="#handleLoadSousModules" styleClass="btn-secondary"/>
                    </HBox>

                    <HBox spacing="15" VBox.vgrow="ALWAYS">
                        <!-- Modules -->
                        <VBox spacing="10" HBox.hgrow="ALWAYS" prefWidth="50%">
                            <Label text="Modules" styleClass="section-title"/>
                            <HBox spacing="5">
                                <TextField fx:id="txtModuleCode" promptText="Code" prefWidth="80" styleClass="text-field-modern"/>
                                <TextField fx:id="txtModuleIntitule" promptText="Intitule" prefWidth="150" styleClass="text-field-modern"/>
                                <TextField fx:id="txtModuleCoef" promptText="Coef" prefWidth="60" styleClass="text-field-modern"/>
                                <Button text="&#10133;" onAction="#handleAjouterModule" styleClass="btn-primary-small"/>
                                <Button text="&#128465;" onAction="#handleSupprimerModule" styleClass="btn-danger-small"/>
                            </HBox>
                            <TableView fx:id="tblModules" VBox.vgrow="ALWAYS" styleClass="table-modern"/>
                        </VBox>

                        <!-- Sous-Modules -->
                        <VBox spacing="10" HBox.hgrow="ALWAYS" prefWidth="50%">
                            <Label text="Sous-Modules" styleClass="section-title"/>
                            <HBox spacing="5">
                                <TextField fx:id="txtSousModuleCode" promptText="Code" prefWidth="80" styleClass="text-field-modern"/>
                                <TextField fx:id="txtSousModuleIntitule" promptText="Intitule" prefWidth="150" styleClass="text-field-modern"/>
                                <TextField fx:id="txtSousModuleCoef" promptText="Coef" prefWidth="60" styleClass="text-field-modern"/>
                                <Button text="&#10133;" onAction="#handleAjouterSousModule" styleClass="btn-primary-small"/>
                            </HBox>
                            <TableView fx:id="tblSousModules" VBox.vgrow="ALWAYS" styleClass="table-modern"/>
                        </VBox>
                    </HBox>
                </VBox>
            </Tab>

            <!-- Tab: Notes -->
            <Tab fx:id="tabNotes" text="&#128221; Notes">
                <VBox spacing="15">
                    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <ComboBox fx:id="cbNotePromotion" promptText="Promotion" prefWidth="180" styleClass="combo-modern"/>
                        <ComboBox fx:id="cbNoteModule" promptText="Module" prefWidth="180" styleClass="combo-modern"/>
                        <ComboBox fx:id="cbNoteSousModule" promptText="Sous-Module" prefWidth="180" styleClass="combo-modern"/>
                        <ComboBox fx:id="cbNoteEtudiant" promptText="Etudiant" prefWidth="180" styleClass="combo-modern"/>
                        <TextField fx:id="txtNoteValeur" promptText="Note (0-20)" prefWidth="80" styleClass="text-field-modern"/>
                        <ComboBox fx:id="cbNoteType" promptText="Type" prefWidth="120" styleClass="combo-modern"/>
                        <Button text="&#128221; Saisir" onAction="#handleSaisirNote" styleClass="btn-primary"/>
                        <Button text="&#9989; Valider" onAction="#handleValiderNotes" styleClass="btn-success"/>
                    </HBox>

                    <TableView fx:id="tblNotes" VBox.vgrow="ALWAYS" styleClass="table-modern"/>
                </VBox>
            </Tab>

            <!-- Tab: Statistiques -->
            <Tab fx:id="tabStats" text="&#128202; Statistiques">
                <VBox spacing="15">
                    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <ComboBox fx:id="cbStatPromotion" promptText="Selectionner promotion" prefWidth="250" styleClass="combo-modern"/>
                        <VBox styleClass="stat-card-small">
                            <Label text="Taux de reussite" styleClass="stat-label-small"/>
                            <Label fx:id="lblTauxReussite" text="-" styleClass="stat-value-small"/>
                        </VBox>
                        <VBox styleClass="stat-card-small">
                            <Label text="Meilleur etudiant" styleClass="stat-label-small"/>
                            <Label fx:id="lblMeilleurEtudiant" text="-" styleClass="stat-value-small"/>
                        </VBox>
                    </HBox>

                    <Label text="Classement" styleClass="section-title"/>
                    <TableView fx:id="tblClassement" VBox.vgrow="ALWAYS" styleClass="table-modern"/>
                </VBox>
            </Tab>

            <!-- Tab: Rapports -->
            <Tab fx:id="tabRapports" text="&#128196; Rapports">
                <VBox spacing="15">
                    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                    <HBox spacing="15">
                        <VBox spacing="10" styleClass="report-card" HBox.hgrow="ALWAYS">
                            <Label text="Rapport par Promotion" styleClass="report-title"/>
                            <ComboBox fx:id="cbRapportPromotion" promptText="Selectionner promotion" prefWidth="250" styleClass="combo-modern"/>
                            <Button text="&#128196; Generer PDF" onAction="#handleGenererRapportPromotion" styleClass="btn-primary" maxWidth="Infinity"/>
                        </VBox>

                        <VBox spacing="10" styleClass="report-card" HBox.hgrow="ALWAYS">
                            <Label text="Rapport par Filiere" styleClass="report-title"/>
                            <ComboBox fx:id="cbRapportFiliere" promptText="Selectionner filiere" prefWidth="250" styleClass="combo-modern"/>
                            <Button text="&#128196; Generer PDF" onAction="#handleGenererRapportFiliere" styleClass="btn-primary" maxWidth="Infinity"/>
                        </VBox>
                    </HBox>

                    <VBox fx:id="vboxRapportResult" spacing="10" VBox.vgrow="ALWAYS"/>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
